# Ignore inbound media (user uploads)
media/inbound/

# Ignore solar-scout generated content
solar-scout/docs/images/*.jpg

# Ignore sensitive files
.env
*.ckpt
*.pem
*.key
*.secret
*.log
.health_check.log
.test_results.log
.security_log

# Ignore runtime/generated
node_modules/
memory/vector-index.json

# Ignore Next.js build artifacts
projects/*/frontend/.next
projects/*/frontend/node_modules
projects/*/frontend/.next/**

# Ignore system-specific scripts
scripts/enable_ollama_control.sh
scripts/openclaw.service
dist/
tsconfig.tsbuildinfo
