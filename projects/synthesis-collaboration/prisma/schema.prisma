// Prisma schema for Synthesis Collaboration Platform
// SQLite MVP

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id // Telegram user ID
  username     String?
  firstName    String
  languageCode String?
  createdAt    DateTime @default(now())

  contributions     Contribution[]
  followUpQuestions FollowUpQuestion[] @relation("toUser")
  personalSpaces    PersonalSpace[]
  votes             Vote[]
  childBots         ChildBot[]
  ownedProjects     Project[]
  contributions2    Contributor[]    @relation("contributorUser")
  syntheses         SynthesisOutput[]
}

model Project {
  id                 String   @id @default(uuid())
  name               String
  description        String?
  challengeStatement String?
  groupId            String?  // Telegram chat ID of shared space group
  status             String   @default("active") // active | archived
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  contributors      Contributor[]
  contributions     Contribution[]
  followUpQuestions FollowUpQuestion[]
  syntheses         SynthesisOutput[]
  wikiPages         WikiPage[]
  childBots         ChildBot[]
  readinessSignals  ReadinessSignal[]
  tasks             Task[]
  entities          Entity[]
  relationships     Relationship[]
  contributionSummaries ContributionSummary[]
}

model Contributor {
  id       String @id @default(uuid())
  projectId String
  userId   String
  role     String @default("contributor") // contributor | lead
  joinedAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("contributorUser", fields: [userId], references: [id], onDelete: Cascade)

  readinessSignal ReadinessSignal?

  @@unique([projectId, userId])
}

model ReadinessSignal {
  id            String   @id @default(uuid())
  status        String   @default("contributing") // contributing | ready | idle
  insightsCount Int      @default(0)
  lastActivity  DateTime @default(now())
  createdAt     DateTime @default(now())

  projectId     String
  contributorId String   @unique

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contributor Contributor @relation(fields: [contributorId], references: [id])

  @@unique([projectId, contributorId])
}

model Contribution {
  id                String   @id @default(uuid())
  content           String
  source            String   @default("group") // group_command | forwarded | followup_answer
  confirmed         Boolean  @default(false)
  crossLinks        String   @default("[]") // JSON array of contribution IDs
  extractionSummary String?
  createdAt         DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  personalSpace PersonalSpace?
}

model FollowUpQuestion {
  id        String   @id @default(uuid())
  question  String
  answer    String?
  answered  Boolean  @default(false)
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  toUserId String?
  toUser   User?   @relation("toUser", fields: [toUserId], references: [id])
}

model PersonalSpace {
  id            String   @id @default(uuid())
  approvedShare Boolean @default(false)
  createdAt     DateTime @default(now())

  contributionId String       @unique
  contribution   Contribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model WikiPage {
  id           String   @id @default(uuid())
  slug         String
  title        String
  content      String   // JSON or markdown
  pageType     String   @default("entity") // entity | concept | summary | source | index | crystallized
  tags         String   @default("[]")     // JSON array
  confidence   Float    @default(0.5)      // 0-1, decays with time, reinforced by confirmation
  lastAccessed DateTime @default(now())   // for retention decay
  lastReinforced DateTime @default(now()) // last time this was confirmed/reinforced
  isStale     Boolean  @default(false)    // superseded or decayed below threshold
  supersededBy String?                    // ID of the WikiPage that superseded this
  sourceContributionId String?            // which contribution created this
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, slug])
}

// ─── Knowledge Graph ──────────────────────────────────────────────────────────
// Typed entities extracted from contributions.
// Follows LLM Wiki v2 pattern: entity extraction + typed relationships + confidence.

model Entity {
  id          String   @id @default(uuid())
  name        String
  entityType  String   // person | concept | tool | project | file | decision | event | unknown
  description String?
  attributes  String   @default("{}") // JSON object of key-value attributes
  confidence  Float    @default(0.5)  // 0-1, reinforced by multiple sources
  sourceCount Int      @default(1)   // how many contributions mentioned this
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isStale     Boolean  @default(false)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Relationships to/from this entity
  outgoing Relationship[] @relation("EntitySource")
  incoming Relationship[] @relation("EntityTarget")

  @@unique([projectId, name])
}

// Typed directed relationships between entities.
// Relationship types carry semantic weight: "uses" ≠ "contradicts" ≠ "caused".
model Relationship {
  id            String   @id @default(uuid())
  sourceId      String
  targetId      String
  relationType  String   // uses | depends_on | caused | contradicts | implements | supersedes | related_to | part_of
  confidence    Float    @default(0.5)   // 0-1
  sourceContributionId String?          // which contribution established this
  createdAt     DateTime @default(now())
  lastReinforced DateTime @default(now())
  isStale       Boolean  @default(false)
  note          String?                  // optional context

  source Entity @relation("EntitySource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Entity @relation("EntityTarget", fields: [targetId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sourceId, targetId, relationType])
}

// ─── Episodic Memory ─────────────────────────────────────────────────────────
// Compressed summaries of contribution sessions.
// Follows consolidation tiers: raw observations → episodic → semantic.

model ContributionSummary {
  id          String   @id @default(uuid())
  sessionKey  String   // groups messages by session (e.g. date, thread ID)
  summary     String   // LLM-generated compressed summary of the session
  keyInsights String   @default("[]") // JSON array of distilled facts
  participantIds String @default("[]") // JSON array of Telegram user IDs
  contributionCount Int @default(0)
  qualityScore Float   @default(0.5) // LLM-assessed quality of this summary
  createdAt   DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SynthesisOutput {
  id                String   @id @default(uuid())
  commonalities     String
  divergences       String
  crossLinksSummary String
  structuredOutline String
  nextSteps         String   // JSON array [{step, votes}]
  rawLlmaResponse   String?  // raw LLM output for debugging
  qualityScore      Float    @default(0.5)  // LLM-assessed quality of synthesis
  crystallized      Boolean  @default(false) // whether this has been filed as wiki pages
  createdAt         DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  generatedById String?
  generatedBy   User?   @relation(fields: [generatedById], references: [id])

  votes Vote[]
}

model Vote {
  id        String   @id @default(uuid())
  stepIndex Int      // 1-3
  createdAt DateTime @default(now())

  synthesisOutputId String
  synthesisOutput   SynthesisOutput @relation(fields: [synthesisOutputId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([synthesisOutputId, userId])
}

model ChildBot {
  id        String   @id @default(uuid())
  username  String?
  botToken  String   // encrypted
  status    String   @default("active") // active | completed | expired
  createdAt DateTime @default(now())
  expiresAt DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  parentUserId String
  parentUser   User   @relation(fields: [parentUserId], references: [id])
}

model Task {
  id        String   @id @default(uuid())
  taskType  String   // ingest | synthesize | lint
  status    String   @default("pending") // pending | processing | done | error
  payload   String   // JSON
  result    String?  // JSON or markdown
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}
