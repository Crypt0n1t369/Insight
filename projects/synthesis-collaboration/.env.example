# Synthesis Collaboration Platform — Environment Variables
# Copy this file to .env and fill in your values

# ── Telegram ───────────────────────────────────────────────────────────────
# Get this from https://t.me/BotFather after creating your bot
TELEGRAM_BOT_TOKEN=7xxxxxx:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Database ───────────────────────────────────────────────────────────────
# SQLite database file (created automatically)
DATABASE_URL="file:./data/synthesis.db"

# ── OpenClaw ───────────────────────────────────────────────────────────────
# Path to OpenClaw workspace (where memory/ directory lives)
OPENCLAW_WORKSPACE=/home/drg/.openclaw/workspace

# URL of OpenClaw gateway (default: local)
OPENCLAW_URL=http://localhost:18789

# ── Server ──────────────────────────────────────────────────────────────────
# Port for any HTTP endpoints (not required for Telegram bot — uses long polling)
PORT=3008
